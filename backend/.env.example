# ── Server ──────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── LLM (Groq) ─────────────────────────────────────
LLM_API_KEY=gsk_your_groq_api_key_here
LLM_PROVIDER=groq

# ── Processing ──────────────────────────────────────
MAX_BATCH_SIZE=20
LLM_CONCURRENCY=1
LLM_MAX_RETRIES=3
LLM_RETRY_BASE_MS=2000
LLM_RETRY_MAX_MS=30000
LLM_REQUEST_DELAY_MS=1500
